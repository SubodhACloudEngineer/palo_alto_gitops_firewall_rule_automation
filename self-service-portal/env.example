# Self-Service Portal Configuration
# Copy this file to .env and update the values:
#   cp env.example .env

# NetBox Configuration
# Required for firewall rule form to fetch VMs, IPs, and Subnets
NETBOX_URL=http://localhost:8000
NETBOX_TOKEN=your_netbox_api_token_here

# Git Configuration (optional)
# Used when committing firewall rules to Git repository
GIT_USER_NAME=Self-Service Portal
GIT_USER_EMAIL=portal@example.com

# AWX Configuration
# Required for triggering Ansible job templates via AWX REST API
AWX_HOST=https://awx.internal.example.com
AWX_TOKEN=your_awx_bearer_token_here
AWX_VERIFY_SSL=true

# Container Registry Configuration
# Used for OpenShift and AKS deployments
IMAGE_REGISTRY=ghcr.io/your-org

# AKS Configuration
# Required for AKS deployments
AKS_CLUSTER_NAME=your-aks-cluster-name
AKS_RESOURCE_GROUP=your-aks-resource-group

# GitHub Configuration (optional)
# Used to fetch latest release tags from GitHub Releases API
# Without token: 60 requests/hour rate limit
# With token: 5000 requests/hour rate limit
GITHUB_TOKEN=your_github_pat_here

# Demo Mode (optional)
# When true, simulates deployments without calling AWX or external systems
# Useful for demos, testing, and development
DEMO_MODE=true
